# ============================================================
# juice-shop-lab environment variables
# Copy to .env and fill in your values before running.
# ============================================================

# ── Neo4j ────────────────────────────────────────────────────
NEO4J_USER=neo4j
# REQUIRED: set a strong password (min 8 chars, Neo4j requirement)
NEO4J_PASSWORD=ChangeMe_Strong_Password_1

# ── Backend VM ───────────────────────────────────────────────
# Public IP or domain of the machine running docker-compose.
# Juice Shop (on Render) will POST logs here.
BACKEND_VM_IP=YOUR.PUBLIC.IP.HERE

# ── Juice Shop (Render) ───────────────────────────────────────
# Full URL of the deployed Juice Shop instance on Render.
# Used by the ZAP scanner and in the render.yaml.
TARGET_URL=https://your-juice-shop.onrender.com

# ── OWASP ZAP ────────────────────────────────────────────────
ZAP_API_KEY=zapapikey
ZAP_HOST=localhost
ZAP_PORT=8090

# ── Logstash ──────────────────────────────────────────────────
# Overrides the default URL inside the Logstash pipeline config.
# Leave blank to use the docker-compose service name default.
# LOG_INGESTION_URL=http://log-ingestion:5001/ingest
