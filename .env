# juice-shop-lab — runtime environment
# Neo4j (local Docker container neo4j-juicelab)
NEO4J_USER=neo4j
NEO4J_PASSWORD=rendertest

# Backend VM public IP — set to your machine's public IP so Render can POST logs here
BACKEND_VM_IP=YOUR.PUBLIC.IP.HERE

# Juice Shop Render URL — fill in after deploying
TARGET_URL=https://your-juice-shop.onrender.com

# ZAP
ZAP_API_KEY=zapapikey
ZAP_HOST=localhost
ZAP_PORT=8090
